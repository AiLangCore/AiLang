Program#cf_p1 {
  Let#cf_l1(name=message) {
    StrConcat#cf_s1 {
      Lit#cf_i1(value="cli-fetch sample: native source compilation is active; full HTTP sample behavior is pending native compile coverage.")
      Lit#cf_i2(value="")
    }
  }
  Call#cf_c1(target=sys.stdout_writeLine) { Var#cf_v1(name=message) }
  Return#cf_r1 { Lit#cf_i3(value=0) }
}
